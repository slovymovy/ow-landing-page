---
import { absoluteUrl, alternateLinks, localeCodes, localizePath, locales, site, type LocaleCode } from '../data/site';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description: string;
  locale?: LocaleCode;
  path?: string;
  noindex?: boolean;
  faq?: { question: string; answer: string }[];
  structuredData?: Record<string, unknown>[];
}

const {
  title,
  description,
  locale = 'en',
  path = '/',
  noindex = false,
  faq = [],
  structuredData = []
} = Astro.props;

const canonicalPath = localizePath(locale, path);
const canonical = absoluteUrl(canonicalPath);
const alternates = alternateLinks(path);
const htmlLang = locales[locale].htmlLang;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: site.name,
    applicationCategory: 'EducationalApplication',
    operatingSystem: 'iOS, Android',
    url: site.origin,
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD'
    },
    description
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: site.name,
    url: site.origin,
    inLanguage: [...localeCodes]
  },
  ...(faq.length > 0
    ? [{
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faq.map((item) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: item.answer
          }
        }))
      }]
    : []),
  ...structuredData
];
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.lang} href={alternate.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={absoluteUrl(localizePath('en', path))} />
    <link rel="icon" type="image/svg+xml" href="/favicon_otter.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@500;600;700&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteUrl(site.ogImage)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteUrl(site.ogImage)} />
    <meta name="theme-color" content="#10151f" />
    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <slot />
    <CookieConsent locale={locale} />
  </body>
</html>

<style is:global>
  :root {
    --night-950: #0d0f16;
    --night-900: #12141C;
    --night-800: #1a1d28;
    --night-700: #252838;
    --night-600: #373b52;
    --night-500: #545870;
    --night-400: #848aab;
    --night-300: #b8bcce;
    --night-200: #d8dae6;
    --cream-100: #f2eee6;
    --cream-200: #e4ddd0;
    --amber-300: #dbbe84;
    --amber-400: #c5a367;
    --amber-500: #b08d4f;
    --line: rgba(255, 255, 255, 0.1);
    --panel: rgba(255, 255, 255, 0.055);
    --panel-strong: rgba(255, 255, 255, 0.085);
    --gradient-night: linear-gradient(180deg, #12141C 0%, #0d0f16 100%);
    --gradient-warm: linear-gradient(135deg, var(--amber-400) 0%, var(--amber-500) 100%);
    --shadow-md: 0 8px 24px -4px rgba(0, 0, 0, 0.4);
    --shadow-lg: 0 16px 48px -8px rgba(0, 0, 0, 0.5);
    --shadow-xl: 0 24px 64px -12px rgba(0, 0, 0, 0.6);
    --shadow-glow: 0 0 60px -10px rgba(197, 163, 103, 0.4);
    --shadow-glow-soft: 0 0 40px -5px rgba(197, 163, 103, 0.25);
    --shadow: var(--shadow-xl);
    --shadow-warm: 0 8px 32px -4px rgba(197, 163, 103, 0.15);
    --radius-xl: 1.25rem;
    --radius-2xl: 1.5rem;
    --radius-full: 9999px;
    --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
    --duration-base: 300ms;
    --font-display: Lora, Georgia, serif;
    --font-body: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    color: var(--night-300);
    background: var(--night-900);
  }

  body {
    margin: 0;
    min-width: 320px;
    font-size: 16px;
    line-height: 1.7;
    background-color: var(--night-900);
    font-family: var(--font-body);
    overflow-x: hidden;
  }

  img,
  svg {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input {
    font: inherit;
  }

  .container {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media (min-width: 768px) {
    .container {
      padding: 0 40px;
    }
  }

  .section {
    padding: 5rem 0;
  }

  .section--tight {
    padding: 48px 0;
  }

  .eyebrow {
    margin: 0 0 12px;
    color: var(--amber-400);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1,
  h2,
  h3 {
    line-height: 1.12;
    letter-spacing: -0.01em;
    color: var(--cream-100);
    font-family: var(--font-display);
    font-weight: 600;
  }

  h1 {
    max-width: 820px;
    margin-bottom: 18px;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
  }

  h2 {
    margin-bottom: 16px;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
  }

  h3 {
    margin-bottom: 10px;
    font-size: 1.1rem;
  }

  .lead {
    max-width: 760px;
    color: var(--night-300);
    font-size: clamp(1rem, 1.5vw, 1.12rem);
  }

  .grid-2 {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
    gap: 44px;
    align-items: center;
  }

  .card {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    backdrop-filter: blur(16px);
    box-shadow: var(--shadow);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  .pill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 22px;
  }

  .pill {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 8px 12px;
    background: rgba(255, 255, 255, 0.06);
    color: var(--cream-200);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .split-band {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background:
      linear-gradient(135deg, rgba(197, 163, 103, 0.08), rgba(110, 198, 184, 0.06)),
      rgba(255, 255, 255, 0.035);
  }

  .quiet-band {
    background: rgba(255, 255, 255, 0.025);
  }

  .dark-band {
    background:
      radial-gradient(circle at 20% 0%, rgba(197, 163, 103, 0.14), transparent 24rem),
      var(--night-950);
    color: var(--cream-100);
  }

  .dark-band .lead,
  .dark-band p {
    color: var(--night-300);
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin: 28px 0 0;
    padding: 0;
    list-style: none;
  }

  .steps li {
    min-height: 118px;
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    color: var(--cream-200);
    font-weight: 750;
    box-shadow: var(--shadow);
  }

  .screen-stack {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    align-items: end;
  }

  .screen-stack img {
    width: 100%;
    border-radius: 22px;
    box-shadow: var(--shadow), var(--shadow-warm);
  }

  .mascot {
    width: min(300px, 76vw);
    margin: 0 auto;
  }

  .word-preview {
    display: grid;
    gap: 14px;
    margin-top: 24px;
  }

  .word-preview__item {
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    box-shadow: var(--shadow);
  }

  .word-preview__word {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 8px;
    font-size: 1.05rem;
    font-weight: 850;
    color: var(--cream-100);
  }

  .word-preview__badge {
    color: var(--amber-400);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  @media (max-width: 820px) {
    .container {
      width: min(100% - 40px, 1120px);
    }

    .section {
      padding: 56px 0;
    }

    .grid-2,
    .steps,
    .screen-stack {
      grid-template-columns: 1fr;
    }

    .steps li {
      min-height: auto;
    }
  }
</style>
