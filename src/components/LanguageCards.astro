---
import { homeCopy } from '../data/copy';
import { languageSlugs, languages, localizePath, type LanguageSlug, type LocaleCode } from '../data/site';

interface Props {
  locale?: LocaleCode;
}

const { locale = 'en' } = Astro.props;
const copy = homeCopy[locale];

// Czech "Učit se" needs the accusative case. `localName` holds the genitive
// form the learn pages rely on (e.g. "slovní zásoba angličtiny"), so the card
// CTA supplies its own accusative form just for Czech.
const csAccusative: Record<LanguageSlug, string> = {
  english: 'angličtinu',
  dutch: 'nizozemštinu',
  polish: 'polštinu',
  russian: 'ruštinu'
};
const ctaName = (slug: LanguageSlug) =>
  locale === 'cs' ? csAccusative[slug] : languages[slug].localName[locale];

// Turkish is verb-final: the object comes before the verb ("İngilizce Öğren",
// not "Öğren İngilizce"), so the CTA flips word order for Turkish.
const ctaText = (slug: LanguageSlug) =>
  locale === 'tr'
    ? `${ctaName(slug)} ${copy.learnVerb}`
    : `${copy.learnVerb} ${ctaName(slug)}`;
---
<div class="lang-grid">
  {languageSlugs.map((slug) => (
    <a class="lang-card" href={localizePath(locale, `/learn/${slug}`)}>
      <div class="lang-card__flag" aria-hidden="true">{languages[slug].flag}</div>
      <div class="lang-card__name">{languages[slug].displayName[locale]}</div>
      <div class="lang-card__cta">
        {ctaText(slug)}
        <span aria-hidden="true">→</span>
      </div>
    </a>
  ))}
</div>

<style>
  /* Compact 2×2 grid on phones — avoids tall stacked cards / dead space. */
  .lang-grid {
    display: grid;
    gap: 10px;
    grid-template-columns: 1fr 1fr;
  }

  @media (min-width: 960px) { .lang-grid { grid-template-columns: repeat(4, 1fr); } }

  .lang-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px 16px 14px;
    background: #1C1F2A;
    border: 1px solid rgba(255, 255, 255, .07);
    border-radius: 16px;
    text-decoration: none;
    transition: border-color .2s, transform .2s, box-shadow .2s;
  }

  @media (min-width: 560px) {
    .lang-card { gap: 8px; padding: 22px 20px 18px; border-radius: 18px; }
  }

  @media (min-width: 960px) {
    .lang-card { gap: 10px; padding: 28px 24px 24px; border-radius: 20px; }
  }

  .lang-card:hover {
    border-color: rgba(197, 163, 103, .4);
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, .3);
  }

  .lang-card__flag { font-size: 1.625rem; line-height: 1; }

  @media (min-width: 560px) { .lang-card__flag { font-size: 2rem; } }

  .lang-card__name {
    font-family: Lora, Georgia, serif;
    font-size: 1rem;
    font-weight: 600;
    color: #E2E4ED;
  }

  @media (min-width: 560px) { .lang-card__name { font-size: 1.125rem; } }

  .lang-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: .8125rem;
    font-weight: 600;
    color: #C5A367;
    margin-top: 2px;
  }

  @media (min-width: 560px) { .lang-card__cta { font-size: .875rem; margin-top: 4px; } }
</style>
