---
import { homeCopy } from '../data/copy';
import { languageSlugs, languages, localizePath, type LocaleCode } from '../data/site';

interface Props {
  locale?: LocaleCode;
}

const { locale = 'en' } = Astro.props;
const copy = homeCopy[locale];
---
<div class="lang-grid">
  {languageSlugs.map((slug) => (
    <a class="lang-card" href={localizePath(locale, `/learn/${slug}`)}>
      <div class="lang-card__flag" aria-hidden="true">{languages[slug].flag}</div>
      <div class="lang-card__name">{languages[slug].displayName[locale]}</div>
      <div class="lang-card__cta">
        {copy.learnVerb} {languages[slug].localName[locale]}
        <span aria-hidden="true">→</span>
      </div>
    </a>
  ))}
</div>

<style>
  .lang-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: 1fr;
  }

  @media (min-width: 560px) { .lang-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 960px) { .lang-grid { grid-template-columns: repeat(4, 1fr); } }

  .lang-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 28px 24px 24px;
    background: #1C1F2A;
    border: 1px solid rgba(255, 255, 255, .07);
    border-radius: 20px;
    text-decoration: none;
    transition: border-color .2s, transform .2s, box-shadow .2s;
  }

  .lang-card:hover {
    border-color: rgba(197, 163, 103, .4);
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, .3);
  }

  .lang-card__flag { font-size: 2rem; line-height: 1; }

  .lang-card__name {
    font-family: Lora, Georgia, serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: #E2E4ED;
  }

  .lang-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: .875rem;
    font-weight: 600;
    color: #C5A367;
    margin-top: 4px;
  }
</style>
