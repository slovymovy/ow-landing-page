---
import { languageSlugs, languages, localizePath, type LocaleCode } from '../data/site';

interface Props {
  locale?: LocaleCode;
}

const { locale = 'en' } = Astro.props;
---
<div class="language-cards">
  {languageSlugs.map((slug) => (
    <a class="language-card" href={localizePath(locale, `/learn/${slug}`)}>
      <span class="language-card__label">{languages[slug].displayName[locale]}</span>
    </a>
  ))}
</div>

<style>
  .language-cards {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    margin-top: 26px;
  }

  .language-card {
    padding: 18px 20px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.055);
    color: #b8bcce;
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.28);
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .language-card:hover {
    border-color: rgba(197, 163, 103, 0.45);
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-2px);
  }

  .language-card__label {
    display: block;
    color: #f2eee6;
    font-size: 1.05rem;
    font-weight: 900;
  }

  @media (max-width: 900px) {
    .language-cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .language-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
