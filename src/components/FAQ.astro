---
interface Props {
  title: string;
  items: { question: string; answer: string }[];
}

const { title, items } = Astro.props;
---
<section class="faq">
  <div class="container">
    <div class="section-head">
      <div class="section-eyebrow">FAQ</div>
      <h2 class="section-h2">{title}</h2>
    </div>
    <div class="faq__list">
      {items.map((item, i) => (
        <details class="faq-item" open={i === 0 || undefined}>
          <summary>
            {item.question}
            <span class="faq-icon" aria-hidden="true">+</span>
          </summary>
          <div class="faq-answer">{item.answer}</div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq {
    background: #0f1118;
    padding: 72px 0;
  }

  .section-head {
    text-align: center;
    margin-bottom: 36px;
  }

  @media (max-width: 640px) {
    .faq { padding: 40px 0; }
    .section-head { margin-bottom: 22px; }
  }

  .section-eyebrow {
    font-size: .6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #C5A367;
    margin-bottom: 10px;
  }

  .section-h2 {
    font-family: Lora, Georgia, serif;
    font-size: clamp(1.625rem, 3.5vw, 2.25rem);
    font-weight: 600;
    line-height: 1.18;
    color: #E2E4ED;
    letter-spacing: -.01em;
  }

  .faq__list {
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .faq-item {
    background: #1C1F2A;
    border: 1px solid rgba(255, 255, 255, .07);
    border-radius: 14px;
    overflow: hidden;
    transition: border-color .2s;
  }

  .faq-item[open] { border-color: rgba(197, 163, 103, .2); }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 24px;
    font-size: .9375rem;
    font-weight: 600;
    color: #E2E4ED;
    cursor: pointer;
    list-style: none;
    user-select: none;
    -webkit-user-select: none;
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, .15);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    line-height: 1;
    color: #C5A367;
    transition: transform .25s, background .2s;
  }

  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
    background: rgba(197, 163, 103, .1);
  }

  .faq-answer {
    padding: 0 24px 20px;
    font-size: .9375rem;
    line-height: 1.77;
    color: #9499B0;
  }
</style>
