---
import { homeCopy } from '../data/copy';
import { languageSlugs, languages, localizePath, site, type LanguageSlug, type LocaleCode } from '../data/site';
import LocaleSwitcher from './LocaleSwitcher.astro';

interface Props {
  locale?: LocaleCode;
  activeLanguage?: LanguageSlug;
  path?: string;
  /** False when the path exists only in the current locale (e.g. /about). */
  localized?: boolean;
}

const { locale = 'en', activeLanguage, path = '/', localized = true } = Astro.props;
const copy = homeCopy[locale];
---
<header class="nav" id="nav">
  <div class="container nav__inner">
    <a class="nav__logo" href={localizePath(locale, '/')}>OpenWords</a>

    <nav class="nav__links" aria-label={copy.ui.mainNavigation}>
      {languageSlugs.map((slug) => (
        <a href={localizePath(locale, `/learn/${slug}`)} class:list={['nav__link', { 'nav__link--active': slug === activeLanguage }]}>
          {languages[slug].displayName[locale]}
        </a>
      ))}
    </nav>

    <div class="nav__right">
      <LocaleSwitcher current={locale} path={path} localized={localized} />

      <a class="nav__cta" href="#download">{copy.navDownload}</a>

      <button
        class="nav__burger"
        id="nav-burger"
        type="button"
        aria-label={copy.ui.openMenu}
        aria-expanded="false"
        aria-controls="nav-drawer"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<div class="drawer" id="nav-drawer" aria-hidden="true">
  <div class="drawer__btns">
    <a href={site.appStoreUrl} target="_blank" rel="noopener noreferrer" class="drawer__btn drawer__btn--gold">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="22" height="22"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
      Download on App Store
    </a>
    <a href={site.googlePlayUrl} target="_blank" rel="noopener noreferrer" class="drawer__btn drawer__btn--dark">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="22" height="22"><path d="M3.18 23.76A1.97 1.97 0 0 1 2 22V2C2 1.26 2.44.62 3.18.24L13.41 12 3.18 23.76zm17.35-8.6L17.4 13.5 14.83 12l2.57-1.5 3.13-1.82a2 2 0 0 1 0 3.48zM4.34 1.15l10.8 6.23L12.52 9.9 4.34 1.15zm0 21.7 8.18-8.74 2.62 2.52-10.8 6.22z"/></svg>
      Get it on Google Play
    </a>
  </div>

  <div>
    <div class="drawer__nav-title">{copy.ui.drawerLearnLabel}</div>
    <div class="drawer__nav-links">
      {languageSlugs.map((slug) => (
        <a href={localizePath(locale, `/learn/${slug}`)} class:list={['drawer__nav-link', { 'drawer__nav-link--active': slug === activeLanguage }]}>
          {languages[slug].displayName[locale]}
        </a>
      ))}
    </div>
  </div>
</div>

<script>
  const nav = document.getElementById('nav');
  const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 16);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const burger = document.getElementById('nav-burger');
  const drawer = document.getElementById('nav-drawer');

  const closeDrawer = () => {
    burger?.classList.remove('is-open');
    drawer?.classList.remove('is-open');
    drawer?.setAttribute('aria-hidden', 'true');
    burger?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  burger?.addEventListener('click', () => {
    const open = burger.classList.toggle('is-open');
    drawer?.classList.toggle('is-open', open);
    drawer?.setAttribute('aria-hidden', String(!open));
    burger.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
    if (open) {
      document.dispatchEvent(new CustomEvent('nav:menu-open', { detail: 'drawer' }));
    }
  });

  drawer?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', closeDrawer);
  });

  // Close the drawer if the locale switcher (or any other nav menu) opens.
  document.addEventListener('nav:menu-open', (e) => {
    if ((e as CustomEvent).detail !== 'drawer') closeDrawer();
  });
</script>

<style>
  /* ── NAV ── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    transition: background .3s, border-color .3s;
    border-bottom: 1px solid transparent;
  }

  .nav.scrolled {
    background: rgba(18, 20, 28, .93);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-color: rgba(255, 255, 255, .07);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    gap: 12px;
  }

  .nav__logo {
    font-family: Lora, Georgia, serif;
    font-weight: 700;
    font-size: 1.25rem;
    color: #E2E4ED;
    flex-shrink: 0;
    letter-spacing: -.01em;
  }

  /* desktop language links */
  .nav__links {
    display: none;
    align-items: center;
    gap: 6px;
    flex: 1;
    padding-left: 24px;
  }

  @media (min-width: 960px) {
    .nav__links { display: flex; }
  }

  .nav__link {
    font-size: .8125rem;
    font-weight: 500;
    color: #9499B0;
    padding: 5px 10px;
    border-radius: 8px;
    transition: color .2s, background .2s;
  }

  .nav__link:hover {
    color: #E2E4ED;
    background: rgba(255, 255, 255, .05);
  }

  .nav__link--active {
    color: #C5A367;
    pointer-events: none;
  }

  /* right cluster */
  .nav__right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  /* nav CTA */
  .nav__cta {
    display: none;
  }

  @media (min-width: 640px) {
    .nav__cta {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 20px;
      border-radius: 999px;
      background: #C5A367;
      color: #1c1407;
      font-weight: 700;
      font-size: .875rem;
      transition: opacity .2s, transform .18s;
    }

    .nav__cta:hover {
      opacity: .88;
      transform: translateY(-1px);
    }
  }

  /* hamburger */
  .nav__burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 4px;
    border-radius: 8px;
    flex-shrink: 0;
    border: none;
    background: none;
    cursor: pointer;
  }

  @media (min-width: 640px) {
    .nav__burger { display: none; }
  }

  .nav__burger span {
    display: block;
    height: 2px;
    background: #E2E4ED;
    border-radius: 2px;
    transition: transform .28s cubic-bezier(.16, 1, .3, 1), opacity .2s;
  }

  .nav__burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav__burger.is-open span:nth-child(2) { opacity: 0; }
  .nav__burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── DRAWER ── */
  .drawer {
    position: fixed;
    top: 60px;
    left: 0;
    right: 0;
    bottom: 0;
    background: #12141C;
    padding: 28px 20px 40px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    transform: translateX(100%);
    transition: transform .35s cubic-bezier(.16, 1, .3, 1);
    z-index: 199;
    overflow-y: auto;
  }

  .drawer.is-open { transform: none; }

  @media (min-width: 640px) {
    .drawer { display: none; }
  }

  .drawer__btns {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .drawer__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 20px;
    border-radius: 14px;
    font-weight: 700;
    font-size: 1rem;
    transition: opacity .2s;
    border: none;
  }

  .drawer__btn:hover { opacity: .85; }

  .drawer__btn--gold {
    background: #C5A367;
    color: #1c1407;
  }

  .drawer__btn--dark {
    background: #191C26;
    border: 1px solid rgba(255, 255, 255, .12);
    color: #E2E4ED;
  }

  .drawer__nav-title {
    font-size: .6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: #555a70;
    margin-bottom: 8px;
  }

  .drawer__nav-links {
    display: flex;
    flex-direction: column;
  }

  .drawer__nav-link {
    padding: 12px 0;
    font-size: .9375rem;
    color: #9499B0;
    border-bottom: 1px solid rgba(255, 255, 255, .07);
    transition: color .2s;
  }

  .drawer__nav-link:last-child {
    border-bottom: none;
  }

  .drawer__nav-link:hover { color: #E2E4ED; }
  .drawer__nav-link--active { color: #C5A367; pointer-events: none; }
</style>
