---
import { homeCopy } from '../data/copy';
import { languageSlugs, languages, locales, localizePath, type LocaleCode } from '../data/site';

interface Props {
  locale?: LocaleCode;
}

const { locale = 'en' } = Astro.props;
const copy = homeCopy[locale];
---
<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__brand" href={localizePath(locale, '/')}>
      <span>OpenWords</span>
    </a>
    <nav class="site-header__nav" aria-label={copy.ui.mainNavigation}>
      {languageSlugs.map((slug) => (
        <a href={localizePath(locale, `/learn/${slug}`)}>{languages[slug].displayName[locale]}</a>
      ))}
    </nav>
    <div class="site-header__right">
      <nav class="site-header__locales" aria-label={copy.ui.languageVersions}>
        {Object.values(locales).map((item) => (
          <a class:list={[item.code === locale && 'is-active']} href={localizePath(item.code, '/')}>{item.code.toUpperCase()}</a>
        ))}
      </nav>
      <a class="site-header__cta" href="#download">{copy.navDownload}</a>
      <button class="site-header__toggle" type="button" aria-label={copy.ui.openMenu} aria-expanded="false" aria-controls="mobile-nav">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
  <div class="mobile-nav" id="mobile-nav" hidden>
    <nav class="mobile-nav__links" aria-label={copy.ui.mobileNavigation}>
      {languageSlugs.map((slug) => (
        <a href={localizePath(locale, `/learn/${slug}`)}>{languages[slug].displayName[locale]}</a>
      ))}
    </nav>
    <nav class="mobile-nav__locales" aria-label={copy.ui.mobileLanguageVersions}>
      {Object.values(locales).map((item) => (
        <a class:list={[item.code === locale && 'is-active']} href={localizePath(item.code, '/')}>{item.nativeLabel}</a>
      ))}
    </nav>
    <a class="mobile-nav__cta" href="#download">{copy.navDownload}</a>
  </div>
</header>

<script>
  const header = document.querySelector('.site-header');
  const toggle = header?.querySelector('.site-header__toggle');
  const menu = header?.querySelector('#mobile-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    menu?.toggleAttribute('hidden', isOpen);
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      menu?.setAttribute('hidden', '');
    });
  });
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(18, 20, 28, 0.9);
    backdrop-filter: blur(16px) saturate(180%);
  }

  .site-header__inner,
  .site-header__brand,
  .site-header__nav,
  .site-header__right,
  .site-header__locales {
    display: flex;
    align-items: center;
  }

  .site-header__inner {
    justify-content: space-between;
    gap: 20px;
  }

  .site-header__brand {
    color: #f2eee6;
    font-family: Lora, Georgia, serif;
    font-size: 1.375rem;
    font-weight: 700;
  }

  .site-header__nav {
    gap: 18px;
    color: #b8bcce;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .site-header__nav a:hover,
  .site-header__locales a:hover {
    color: #c5a367;
  }

  .site-header__right {
    gap: 0.75rem;
  }

  .site-header__locales {
    gap: 4px;
    font-size: 0.78rem;
    font-weight: 850;
  }

  .site-header__locales a {
    padding: 5px 7px;
    border-radius: 6px;
    color: #848aab;
  }

  .site-header__locales .is-active {
    background: rgba(197, 163, 103, 0.14);
    color: #dbbe84;
  }

  .site-header__cta {
    border-radius: 1.25rem;
    padding: 0.9rem 1.35rem;
    background: linear-gradient(135deg, #c5a367, #b08d4f);
    color: #0d0f16;
    font-size: 0.9375rem;
    font-weight: 700;
    box-shadow: 0 8px 24px -4px rgba(0, 0, 0, 0.4), 0 0 40px -5px rgba(197, 163, 103, 0.25);
  }

  .site-header__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0.55rem;
    border: 0;
    background: transparent;
  }

  .site-header__toggle span {
    display: block;
    width: 22px;
    height: 2px;
    border-radius: 2px;
    background: #e4ddd0;
  }

  .mobile-nav {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 1rem 1.5rem 1.25rem;
    background: rgba(13, 15, 22, 0.96);
  }

  .mobile-nav__links,
  .mobile-nav__locales {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .mobile-nav__links a,
  .mobile-nav__locales a {
    display: flex;
    align-items: center;
    min-height: 2.5rem;
    padding: 0.55rem 0.75rem;
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.035);
    color: #e4ddd0;
    font-weight: 700;
  }

  .mobile-nav__locales {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .mobile-nav__locales a {
    color: #848aab;
    font-size: 0.875rem;
  }

  .mobile-nav__locales .is-active {
    color: #dbbe84;
  }

  .mobile-nav__cta {
    display: flex;
    justify-content: center;
    margin-top: 1rem;
    border-radius: 1.25rem;
    padding: 0.875rem 1rem;
    background: linear-gradient(135deg, #c5a367, #b08d4f);
    color: #0d0f16;
    font-weight: 800;
  }

  @media (max-width: 940px) {
    .site-header__nav {
      display: none;
    }

    .site-header__cta {
      display: inline-flex;
      padding: 0.7rem 1rem;
      border-radius: 1.1rem;
      font-size: 0.875rem;
    }

    .site-header__toggle {
      display: flex;
    }
  }

  @media (max-width: 560px) {
    .site-header__locales {
      display: none;
    }

    .site-header {
      padding: 0.85rem 0;
    }

    .site-header__brand {
      font-size: 1.2rem;
    }

    .site-header__cta {
      display: none;
    }

    .mobile-nav {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
</style>
