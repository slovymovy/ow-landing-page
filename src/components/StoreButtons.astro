---
import { site } from '../data/site';

interface Props {
  locale?: 'en' | 'pl' | 'nl' | 'ru';
  appStoreLabel?: string;
  googlePlayLabel?: string;
}

const {
  locale = 'en',
  appStoreLabel = 'App Store',
  googlePlayLabel = 'Google Play'
} = Astro.props;

const label = {
  en: ['Download on the', 'Get it on'],
  pl: ['Pobierz z', 'Pobierz z'],
  nl: ['Download in de', 'Download via'],
  ru: ['Скачать в', 'Скачать в']
}[locale];
---
<div class="download-buttons">
  <a class="download-btn download-btn--primary" href={site.appStoreUrl} target="_blank" rel="noopener noreferrer">
    <svg class="download-btn__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
    </svg>
    <span class="download-btn__text">
      <span class="download-btn__small">{label[0]}</span>
      <span class="download-btn__big">{appStoreLabel}</span>
    </span>
  </a>
  <a class="download-btn" href={site.googlePlayUrl} target="_blank" rel="noopener noreferrer">
    <svg class="download-btn__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M3.18 23.76A1.97 1.97 0 0 1 2 22V2C2 1.26 2.44.62 3.18.24L13.41 12 3.18 23.76zm17.35-8.6L17.4 13.5 14.83 12l2.57-1.5 3.13-1.82a2 2 0 0 1 0 3.48zM4.34 1.15l10.8 6.23L12.52 9.9 4.34 1.15zm0 21.7 8.18-8.74 2.62 2.52-10.8 6.22z"/>
    </svg>
    <span class="download-btn__text">
      <span class="download-btn__small">{label[1]}</span>
      <span class="download-btn__big">{googlePlayLabel}</span>
    </span>
  </a>
</div>

<style>
  .download-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    justify-content: center;
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    min-width: 138px;
    padding: 0.55rem 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-xl);
    background: rgba(255, 255, 255, 0.06);
    color: var(--cream-100);
    transition: all var(--duration-base) var(--ease-out);
  }

  .download-btn:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.1);
  }

  .download-btn--primary {
    border-color: transparent;
    background: var(--gradient-warm);
    color: var(--night-950);
    box-shadow: var(--shadow-md), var(--shadow-glow-soft);
  }

  .download-btn--primary:hover {
    border-color: transparent;
    background: var(--gradient-warm);
    color: var(--night-950);
    box-shadow: var(--shadow-lg), var(--shadow-glow);
  }

  .download-btn__icon {
    width: 19px;
    height: 19px;
    flex-shrink: 0;
  }

  .download-btn__text {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .download-btn__small {
    font-size: 0.58rem;
    font-weight: 500;
    line-height: 1;
    opacity: 0.7;
  }

  .download-btn__big {
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.3;
  }
</style>
