---
import { site, type LocaleCode } from '../data/site';

interface Props {
  locale?: LocaleCode;
}

const { locale = 'en' } = Astro.props;

const copy = {
  en: {
    text: "We use Google Analytics to count visits - that's why there's a cookie.",
    privacy: 'Privacy Policy',
    accept: 'Accept',
    decline: 'Decline'
  },
  pl: {
    text: 'Używamy Google Analytics do liczenia wizyt - dlatego potrzebny jest plik cookie.',
    privacy: 'Polityka prywatności',
    accept: 'Akceptuję',
    decline: 'Odmawiam'
  },
  nl: {
    text: 'We gebruiken Google Analytics om bezoeken te tellen - daarom is er een cookie nodig.',
    privacy: 'Privacybeleid',
    accept: 'Accepteren',
    decline: 'Weigeren'
  },
  ru: {
    text: 'Мы используем Google Analytics для подсчета посещений - поэтому нужен cookie.',
    privacy: 'Политика конфиденциальности',
    accept: 'Принять',
    decline: 'Отклонить'
  }
}[locale];
---
<div class="cookie-banner" id="cookie-banner" hidden>
  <p class="cookie-banner__text">{copy.text} <a href="/privacy/">{copy.privacy}</a>.</p>
  <div class="cookie-banner__actions">
    <button class="cookie-btn cookie-btn--accept" id="cookie-accept" type="button">{copy.accept}</button>
    <button class="cookie-btn cookie-btn--decline" id="cookie-decline" type="button">{copy.decline}</button>
  </div>
</div>

<script define:vars={{ measurementId: site.gaMeasurementId }}>
  const CONSENT_KEY = 'ow_cookie_consent';
  const banner = document.getElementById('cookie-banner');
  const accept = document.getElementById('cookie-accept');
  const decline = document.getElementById('cookie-decline');

  function loadGA() {
    if (window.gtag) return;

    const script = document.createElement('script');
    script.async = true;
    script.src = `https://www.googletagmanager.com/gtag/js?id=${measurementId}`;
    document.head.appendChild(script);

    window.dataLayer = window.dataLayer || [];
    function gtag() {
      window.dataLayer.push(arguments);
    }
    window.gtag = gtag;
    gtag('js', new Date());
    gtag('config', measurementId);
  }

  const consent = localStorage.getItem(CONSENT_KEY);
  if (consent === 'accepted') {
    loadGA();
  } else if (consent === null) {
    banner?.removeAttribute('hidden');
  }

  accept?.addEventListener('click', () => {
    localStorage.setItem(CONSENT_KEY, 'accepted');
    banner?.setAttribute('hidden', '');
    loadGA();
  });

  decline?.addEventListener('click', () => {
    localStorage.setItem(CONSENT_KEY, 'declined');
    banner?.setAttribute('hidden', '');
  });
</script>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    z-index: 40;
    display: flex;
    width: calc(100% - 3rem);
    max-width: 600px;
    flex-direction: column;
    gap: 1rem;
    transform: translateX(-50%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-xl);
    padding: 1.25rem 1.5rem;
    background: var(--night-800);
    box-shadow: var(--shadow-xl);
  }

  .cookie-banner[hidden] {
    display: none;
  }

  .cookie-banner__text {
    margin: 0;
    color: var(--night-300);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .cookie-banner__text a {
    color: var(--amber-400);
    text-decoration: underline;
  }

  .cookie-banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .cookie-btn {
    cursor: pointer;
    border: 0;
    border-radius: var(--radius-full);
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 700;
    transition: opacity 150ms;
  }

  .cookie-btn:hover {
    opacity: 0.85;
  }

  .cookie-btn--accept {
    background: var(--gradient-warm);
    color: var(--night-950);
  }

  .cookie-btn--decline {
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: transparent;
    color: var(--night-300);
  }

  @media (min-width: 640px) {
    .cookie-banner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .cookie-banner__text {
      flex: 1;
    }

    .cookie-banner__actions {
      flex-shrink: 0;
    }
  }
</style>
