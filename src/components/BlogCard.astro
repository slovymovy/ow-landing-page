---
interface Props {
  href: string;
  title: string;
  excerpt: string;
  pills: string[];
  /** Space-separated controlled tag keys, used by the client-side filter. */
  dataTags: string;
  dateLabel: string;
  readMins: number;
}

const { href, title, excerpt, pills, dataTags, dateLabel, readMins } = Astro.props;
---
<a class="card reveal" href={href} data-tags={dataTags}>
  <div class="card__body">
    <div class="card__pills">
      {pills.map((pill) => <span class="card__pill">{pill}</span>)}
    </div>
    <h3 class="card__title">{title}</h3>
    <p class="card__excerpt">{excerpt}</p>
    <div class="card__foot">
      <span class="card__meta">{dateLabel}<span class="dot">·</span>{readMins} min read</span>
    </div>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: #1C1F2A;
    border: 1px solid rgba(255, 255, 255, .07);
    border-radius: 20px;
    overflow: hidden;
    transition: border-color .22s, transform .22s, box-shadow .22s;
  }

  .card:hover {
    border-color: rgba(197, 163, 103, .20);
    transform: translateY(-4px);
    box-shadow: 0 14px 40px rgba(0, 0, 0, .34);
  }

  .card:focus-visible {
    outline: 2px solid #C5A367;
    outline-offset: 3px;
  }

  .card__body {
    padding: 24px 24px 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 14px;
  }

  .card__pill {
    font-size: .625rem;
    font-weight: 700;
    letter-spacing: .05em;
    text-transform: uppercase;
    color: #9499B0;
    border: 1px solid rgba(255, 255, 255, .07);
    padding: 3px 9px;
    border-radius: 999px;
  }

  .card__title {
    font-family: Lora, Georgia, serif;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.28;
    letter-spacing: -.01em;
    color: #E2E4ED;
    margin: 0 0 10px;
    transition: color .2s;
  }

  .card:hover .card__title {
    color: #C5A367;
  }

  .card__excerpt {
    font-size: .9375rem;
    line-height: 1.6;
    color: #9499B0;
    margin: 0 0 18px;
  }

  .card__foot {
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid rgba(255, 255, 255, .07);
  }

  .card__meta {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: .6875rem;
    letter-spacing: .04em;
    color: #555a70;
  }

  .card__meta .dot {
    margin: 0 7px;
    opacity: .6;
  }

  .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity .6s ease, transform .6s ease;
  }

  .reveal.in {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
