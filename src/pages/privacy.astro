---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PrivacyPolicyContent from '../components/PrivacyPolicyContent.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const locale = 'en';
---
<BaseLayout
  title="Privacy Policy – OpenWords"
  description="Privacy policy for the OpenWords mobile application."
  path="/privacy"
  noindex
>
  <Header locale={locale} />

  <main class="section privacy">
    <div class="container privacy__content">
      <PrivacyPolicyContent />
    </div>
  </main>

  <Footer locale={locale} />
</BaseLayout>

<style>
  .privacy__content {
    max-width: 820px;
  }

  .privacy {
    padding-top: calc(80px + 3rem);
  }

  .privacy section {
    padding: 28px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .privacy section:first-of-type {
    border-top: 0;
  }

  .privacy ul {
    margin: 0.75rem 0 0;
    padding-left: 1.25rem;
  }

  .privacy li {
    margin-bottom: 0.625rem;
    color: #b8bcce;
  }

  .privacy a {
    color: #c5a367;
    font-weight: 750;
  }

  .prev-version {
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .prev-version summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    color: #848aab;
    font-size: 0.8125rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .prev-version summary::-webkit-details-marker {
    display: none;
  }

  .prev-version .chevron {
    width: 14px;
    height: 14px;
    min-width: 14px;
    max-width: 14px;
    flex: 0 0 14px;
    transition: transform 200ms ease;
  }

  .prev-version[open] .chevron {
    transform: rotate(90deg);
  }

  .prev-version__body {
    margin-top: 2rem;
    padding: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.04);
  }
</style>
