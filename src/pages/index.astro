---
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import LanguageCards from '../components/LanguageCards.astro';
import MobileDownloadBar from '../components/MobileDownloadBar.astro';
import StoreButtons from '../components/StoreButtons.astro';
import { cardDemo, homeCopy, homeFaq } from '../data/copy';
import { languageSlugs, languages } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';

const locale = 'en';
const copy = homeCopy[locale];
const demo = cardDemo[locale];
const faq = homeFaq(locale);
---
<BaseLayout title={copy.title} description={copy.description} locale={locale} path="/" faq={faq}>
  <Header locale={locale} />

  <main>
    <section class="hero">
      <div class="hero__glow" aria-hidden="true"></div>
      <div class="container">
        <div class="hero__inner">
          <div class="hero__text">
            <div class="hero__eyebrow">
              <span class="eyebrow-dot" aria-hidden="true"></span>
              {copy.heroEyebrow}
            </div>
            <h1 class="hero__h1" set:html={copy.heroH1Html}></h1>
            <p class="hero__sub">{copy.subtitle}</p>
            <div class="hero__actions">
              <StoreButtons locale={locale} />
              <p class="hero__tagline">{copy.heroTagline}</p>
              <div class="hero__chips" aria-label={copy.ui.supportedLanguages}>
                {languageSlugs.map((slug) => (
                  <span class="chip">{languages[slug].displayName[locale]}</span>
                ))}
              </div>
            </div>
          </div>
          <div class="hero__visual">
            <img class="hero__mascot" src="/svg_final_search_otter.dark.optimized.svg" alt={copy.ui.searchMascotAlt} width="340" height="340" fetchpriority="high" />
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <section class="problem">
      <div class="container">
        <div class="problem__head">
          <h2 class="problem__title" set:html={copy.problemTitleHtml}></h2>
          <p class="problem__lead">{copy.problemLead}</p>
        </div>

        <div class="ba">
          <div class="ba__card ba__card--before">
            <div class="ba__label">{copy.beforeLabel}</div>
            <p class="ba__text">{copy.beforeText}</p>
          </div>

          <div class="ba__arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
          </div>

          <div class="ba__card ba__card--after">
            <div class="ba__label ba__label--gold">{copy.afterLabel}</div>
            <p class="ba__text">{copy.afterText}</p>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <section class="how" id="how-it-works">
      <div class="container">

        <div class="section-head">
          <div class="section-eyebrow">{copy.howItWorksEyebrow}</div>
          <h2 class="section-h2">{copy.howItWorksTitle}</h2>
        </div>

        <div class="how__flow" aria-hidden="true">
          <div class="how__step-chip">{copy.howStepChips[0]}</div>
          <span class="how__connector">→</span>
          <div class="how__step-chip">{copy.howStepChips[1]}</div>
          <span class="how__connector">→</span>
          <div class="how__step-chip">{copy.howStepChips[2]}</div>
          <span class="how__connector">→</span>
          <div class="how__step-chip">{copy.howStepChips[3]}</div>
        </div>

        <div class="how__row how__row--first">
          <div class="how__text">
            <span class="how__num" aria-hidden="true">01</span>
            <h3 class="how__h3">{copy.loopTitle}</h3>
            <p class="how__body">{copy.loop}</p>
            <p class="how__body">{copy.loop2}</p>
          </div>
          <div class="how__visual">
            <div class="phone-wrap">
              <picture>
                <source type="image/avif" srcset="/word.avif" />
                <source type="image/webp" srcset="/word.webp" />
                <img src="/word.jpg" alt={copy.ui.searchScreenAlt} loading="lazy" width="260" height="565" />
              </picture>
            </div>
          </div>
        </div>

        <div class="how__row how__row--rev">
          <div class="how__text">
            <span class="how__num" aria-hidden="true">02</span>
            <h3 class="how__h3">{copy.dictionaryTitle}</h3>
            <p class="how__body">{copy.dictionary}</p>
          </div>
          <div class="how__visual">
            <div class="phone-wrap">
              <picture>
                <source type="image/avif" srcset="/sense.avif" />
                <source type="image/webp" srcset="/sense.webp" />
                <img src="/sense.jpg" alt={copy.ui.meaningCardAlt} loading="lazy" width="260" height="565" />
              </picture>
            </div>
          </div>
        </div>

        <div class="how__row">
          <div class="how__text">
            <span class="how__num" aria-hidden="true">03</span>
            <h3 class="how__h3">{copy.srsTitle}</h3>
            <p class="how__body">{copy.srs}</p>
          </div>
          <div class="how__visual">
            <div class="phone-wrap">
              <picture>
                <source type="image/avif" srcset="/favs.avif" />
                <source type="image/webp" srcset="/favs.webp" />
                <img src="/favs.jpg" alt={copy.ui.savedScreenAlt} loading="lazy" width="260" height="565" />
              </picture>
            </div>
          </div>
        </div>

        <div class="card-types">
          <div class="card-types__head">
            <div class="card-types__eyebrow">{copy.cardTypesEyebrow}</div>
            <p class="card-types__title">{copy.cardTypesTitle}</p>
          </div>
          <div class="card-types__strip">

            <div class="card-prev" role="img" aria-label={`${demo.targetCode} → ${demo.locCode}: ${demo.word}`}>
              <div class="card-prev__chip card-prev__chip--recog">{demo.targetCode} → {demo.locCode}</div>
              <div class="card-prev__body">
                <div class="card-prev__word">{demo.word} <span class="card-prev__speaker" aria-hidden="true">🔊</span></div>
              </div>            </div>

            <div class="card-prev" role="img" aria-label={demo.translatePrompt}>
              <div class="card-prev__chip card-prev__chip--prod">{demo.locCode} → {demo.targetCode}</div>
              <div class="card-prev__body">
                <div class="card-prev__prompt">{demo.translatePrompt}</div>
                <div class="card-prev__word card-prev__word--sm" set:html={demo.translation}></div>
              </div>            </div>

            <div class="card-prev" role="img" aria-label={demo.fillInChip}>
              <div class="card-prev__chip card-prev__chip--cloze">{demo.fillInChip}</div>
              <div class="card-prev__body">
                <div class="card-prev__cloze">{demo.clozeBefore} <span class="card-prev__blank">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>{demo.clozeAfter}</div>
              </div>            </div>

            <div class="card-prev" role="img" aria-label={demo.listenChip}>
              <div class="card-prev__chip card-prev__chip--listen">{demo.listenChip}</div>
              <div class="card-prev__body card-prev__body--center">
                <div class="card-prev__disc">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 5L6 9H2v6h4l5 4V5z"/><path d="M15.5 8.5a5 5 0 0 1 0 7"/><path d="M19 5.5a9 9 0 0 1 0 13"/></svg>
                </div>
              </div>            </div>

            <div class="card-prev" role="img" aria-label={`${demo.monoChip}: ${demo.word}`}>
              <div class="card-prev__chip card-prev__chip--mono">{demo.monoChip}</div>
              <div class="card-prev__body">
                <div class="card-prev__word">{demo.word} <span class="card-prev__speaker" aria-hidden="true">🔊</span></div>
                <div class="card-prev__mono-note">{demo.thinkIn}</div>
              </div>            </div>

          </div>
        </div>

        <div class="how__row how__row--rev">
          <div class="how__text">
            <span class="how__num" aria-hidden="true">04</span>
            <h3 class="how__h3">{copy.trackTitle}</h3>
            <p class="how__body">{copy.track}</p>
          </div>
          <div class="how__visual">
            <div class="phone-wrap">
              <picture>
                <source type="image/avif" srcset="/screen-stats.avif" />
                <source type="image/webp" srcset="/screen-stats.webp" />
                <img src="/screen-stats.png" alt={copy.ui.statsScreenAlt} loading="lazy" width="260" height="565" />
              </picture>
            </div>
          </div>
        </div>

      </div>
    </section>

    <div class="divider"></div>

    <section class="forme">
      <div class="container">
        <div class="section-head">
          <div class="section-eyebrow">{copy.formeEyebrow}</div>
          <h2 class="section-h2">{copy.formeTitle}</h2>
        </div>
        <ul class="forme__list">
          {copy.formeItems.map((item) => (
            <li class="forme__item">
              <span class="forme__check" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </span>
              <div>
                <div class="forme__lead">{item.lead}</div>
                <div class="forme__desc">{item.desc}</div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <div class="divider"></div>

    <section class="languages">
      <div class="container">
        <div class="section-head">
          <div class="section-eyebrow">{copy.languagesEyebrow}</div>
          <h2 class="section-h2">{copy.languagesTitle}</h2>
          <p class="section-sub">{copy.languagesSubtitle}</p>
        </div>
        <LanguageCards locale={locale} />
      </div>
    </section>

    <div class="divider"></div>

    <FAQ title={copy.faqTitle} items={faq} />

    <section class="cta" id="download">
      <div class="cta__glow" aria-hidden="true"></div>
      <div class="container">
        <div class="cta__inner">
          <div class="cta__mascot">
            <img src="/svg_final_otter_favourites.dark.optimized.svg" alt={copy.ui.savedMascotAlt} width="280" />
          </div>
          <div class="cta__body">
            <div class="cta__eyebrow">{copy.eyebrow}</div>
            <h2 class="cta__h2">{copy.finalCta}</h2>
            <p class="cta__sub">{copy.ctaSub}</p>
            <div class="cta__btns">
              <StoreButtons locale={locale} />
            </div>
            <p class="cta__note">{copy.heroTagline}</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <MobileDownloadBar locale={locale} />

  <Footer locale={locale} />
</BaseLayout>

<style>
  /* ── HERO ── */
  .hero {
    display: flex;
    align-items: center;
    padding-top: 60px;
    position: relative;
    overflow: hidden;
  }

  .hero__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(197, 163, 103, .09) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
    align-items: center;
    padding: 40px 0 56px;
    width: 100%;
  }

  .hero__text { order: 1; }
  .hero__visual { order: 2; display: flex; justify-content: center; }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: .8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .09em;
    color: #C5A367;
    margin-bottom: 18px;
  }

  .eyebrow-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #C5A367;
    box-shadow: 0 0 8px #C5A367;
    animation: pulse-dot 2.5s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: .5; transform: scale(1.6); }
  }

  .hero__h1 {
    font-family: Lora, Georgia, serif;
    font-size: clamp(2.25rem, 9vw, 3.5rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -.015em;
    color: #E2E4ED;
    margin-bottom: 20px;
  }

  .hero__h1 :global(em) {
    font-style: normal;
    color: #C5A367;
  }

  .hero__sub {
    font-size: clamp(1rem, 2vw, 1.0625rem);
    line-height: 1.8;
    color: #9499B0;
    max-width: 520px;
    margin-top: 8px;
    margin-bottom: 32px;
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .hero__tagline {
    font-size: .8125rem;
    color: #868ca6;
    margin: 0;
    padding-top: 4px;
  }

  .hero__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }

  .chip {
    font-size: .8125rem;
    font-weight: 500;
    color: #9499B0;
    padding: 5px 14px;
    border: 1px solid rgba(255, 255, 255, .07);
    border-radius: 999px;
  }

  .hero__mascot {
    width: clamp(140px, 38vw, 280px);
    height: auto;
    margin: 0 auto;
    animation: float-mascot 6s ease-in-out infinite;
    filter: drop-shadow(0 12px 40px rgba(197, 163, 103, .18));
  }

  @keyframes float-mascot {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  @media (min-width: 860px) {
    .hero {
      min-height: auto;
    }

    .hero__inner {
      grid-template-columns: 1fr 360px;
      gap: 64px;
      padding: 72px 0 76px;
    }

    .hero__text { order: 1; }
    .hero__visual { order: 2; }
  }

  /* ── PROBLEM / BEFORE-AFTER ── */
  .problem {
    background: #0f1118;
    padding: 72px 0;
  }

  .problem__head {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 36px;
  }

  .problem__title {
    font-family: Lora, Georgia, serif;
    font-size: clamp(1.75rem, 4vw, 2.625rem);
    font-weight: 600;
    line-height: 1.18;
    color: #E2E4ED;
    letter-spacing: -.01em;
    margin-bottom: 14px;
  }

  .problem__title :global(em) {
    font-style: italic;
    color: #C5A367;
  }

  .problem__lead {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #9499B0;
    margin: 0;
  }

  .ba {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    max-width: 880px;
    margin: 0 auto;
    align-items: stretch;
  }

  @media (min-width: 760px) {
    .ba { grid-template-columns: 1fr auto 1fr; gap: 18px; align-items: center; }
  }

  .ba__card {
    border-radius: 20px;
    padding: 32px 30px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    height: 100%;
    justify-content: center;
  }

  .ba__card--before {
    background: #191C26;
    border: 1px solid rgba(255, 255, 255, .07);
  }

  .ba__card--after {
    background: linear-gradient(180deg, rgba(197, 163, 103, .12), rgba(197, 163, 103, .03));
    border: 1px solid rgba(197, 163, 103, .20);
    box-shadow: 0 20px 54px rgba(0, 0, 0, .4);
  }

  .ba__label {
    font-size: .6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .11em;
    color: #868ca6;
  }

  .ba__label--gold { color: #C5A367; }

  .ba__text {
    font-size: clamp(1.125rem, 2.4vw, 1.375rem);
    font-weight: 500;
    line-height: 1.4;
    color: #9499B0;
    letter-spacing: -.005em;
    margin: 0;
  }

  .ba__card--after .ba__text { color: #E2E4ED; }

  .ba__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #C5A367;
  }

  .ba__arrow svg { width: 26px; height: 26px; }

  @media (max-width: 759px) {
    .ba__arrow { transform: rotate(90deg); margin: -2px 0; }
  }

  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(197, 163, 103, 0.14), transparent);
  }

  /* ── HOW IT WORKS ── */
  .how { padding: 56px 0 32px; }

  .section-head { text-align: center; margin-bottom: 36px; }

  .section-eyebrow {
    font-size: .6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #C5A367;
    margin-bottom: 10px;
  }

  .section-h2 {
    font-family: Lora, Georgia, serif;
    font-size: clamp(1.625rem, 3.5vw, 2.25rem);
    font-weight: 600;
    line-height: 1.18;
    color: #E2E4ED;
    letter-spacing: -.01em;
    margin-bottom: 12px;
  }

  .section-sub {
    font-size: 1rem;
    color: #9499B0;
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .how__flow {
    display: none;
  }

  @media (min-width: 800px) {
    .how__flow {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
      margin-bottom: 72px;
    }
  }

  .how__step-chip {
    padding: 7px 18px;
    border-radius: 999px;
    background: #1C1F2A;
    border: 1px solid rgba(255, 255, 255, .07);
    font-size: .8rem;
    font-weight: 700;
    color: #868ca6;
    letter-spacing: .04em;
    white-space: nowrap;
  }

  .how__connector {
    color: #868ca6;
    font-size: 1rem;
    padding: 0 10px;
    opacity: .5;
  }

  .how__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
    padding: 56px 0;
    border-top: 1px solid rgba(255, 255, 255, .07);
  }

  .how__row--first {
    border-top: none;
    padding-top: 0;
  }

  .how__num {
    font-family: Lora, Georgia, serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1;
    color: rgba(197, 163, 103, .22);
    margin-bottom: 2px;
    display: block;
  }

  .how__h3 {
    font-family: Lora, Georgia, serif;
    font-size: clamp(1.375rem, 3vw, 2rem);
    font-weight: 600;
    line-height: 1.18;
    color: #E2E4ED;
    margin-bottom: 14px;
    letter-spacing: -.01em;
  }

  .how__body {
    font-size: 1rem;
    line-height: 1.8;
    color: #9499B0;
    margin: 0;
  }

  .how__body + .how__body { margin-top: 12px; }

  .how__visual { display: flex; justify-content: center; }

  /* ── CARD TYPE STRIP ── */
  .card-types {
    border-top: 1px solid rgba(255, 255, 255, .07);
    padding: 48px 0 64px;
  }

  .card-types__head {
    text-align: center;
    margin-bottom: 32px;
  }

  .card-types__eyebrow {
    font-size: .6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #C5A367;
    margin-bottom: 6px;
  }

  .card-types__title {
    font-family: Lora, Georgia, serif;
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 500;
    color: #9499B0;
    font-style: italic;
    margin: 0;
  }

  .card-types__strip {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 8px 4px 24px;
    justify-content: safe center;
  }

  .card-types__strip::-webkit-scrollbar { display: none; }

  /* ── Mini card previews ── */
  .card-prev {
    width: 156px;
    flex-shrink: 0;
    background: #f5f2ed;
    border-radius: 18px;
    padding: 14px 13px 11px;
    box-shadow: 0 0 0 1px rgba(255,255,255,.06), 0 2px 8px rgba(0,0,0,.22), 0 14px 36px rgba(0,0,0,.28);
    display: flex;
    flex-direction: column;
    height: 216px;
  }

  .card-prev__chip {
    display: inline-flex;
    align-items: center;
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 700;
    font-family: Inter, sans-serif;
    letter-spacing: .02em;
    align-self: flex-start;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .card-prev__chip--recog { background: #d7eacc; color: #265c1c; }
  .card-prev__chip--prod  { background: #e8d8c6; color: #3b1e08; }
  .card-prev__chip--cloze { background: #f3e3bc; color: #472c00; }
  .card-prev__chip--listen{ background: #d2e4f4; color: #0c3054; }
  .card-prev__chip--mono  { background: #fddcc2; color: #2d1400; }

  .card-prev__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    padding: 8px 0 4px;
  }

  .card-prev__body--center { align-items: center; }

  .card-prev__prompt {
    font-size: 9.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #6f6359;
    font-family: Inter, sans-serif;
    text-align: center;
  }

  .card-prev__word {
    font-family: Lora, Georgia, serif;
    font-size: 24px;
    font-weight: 500;
    color: #2d2620;
    text-align: center;
    line-height: 1.1;
    letter-spacing: -.01em;
  }

  .card-prev__word--sm { font-size: 18px; }
  .card-prev__speaker { font-size: 13px; opacity: .55; }

  .card-prev__mono-note {
    font-size: 10px;
    color: #6f6359;
    text-align: center;
    font-family: Inter, sans-serif;
    font-style: italic;
  }

  .card-prev__cloze {
    font-family: Lora, Georgia, serif;
    font-size: 15px;
    color: #2d2620;
    line-height: 1.55;
    text-align: center;
  }

  .card-prev__blank {
