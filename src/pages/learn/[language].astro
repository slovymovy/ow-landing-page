<script>
  const nav = document.getElementById('nav');
  if (nav) {
    window.addEventListener('scroll', () => nav.classList.toggle('scrolled', window.scrollY > 16), { passive: true });
    nav.classList.toggle('scrolled', window.scrollY > 16);
  }

  const cefrScale = document.querySelector('.cefr-scale');
  if (cefrScale) {
    const barObs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          (e.target as Element).querySelectorAll<HTMLElement>('.cefr-bar').forEach(bar => {
            bar.style.width = bar.dataset.width ?? '0%';
          });
          barObs.unobserve(e.target);
        }
      });
    }, { threshold: 0.3 });
    barObs.observe(cefrScale);
  }

  const revObs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); revObs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => revObs.observe(el));

  document.querySelectorAll('details.sense').forEach(d => {
    d.addEventListener('toggle', () => {
      if ((d as HTMLDetailsElement).open) {
        document.querySelectorAll('details.sense').forEach(other => {
          if (other !== d) (other as HTMLDetailsElement).open = false;
        });
      }
    });
  });
</script>
