---
import FAQ from '../../../components/FAQ.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import StoreButtons from '../../../components/StoreButtons.astro';
import { homeCopy, learnCopy, learnFaq } from '../../../data/copy';
import { languageSlugs, languages, locales, type LanguageSlug, type LocaleCode } from '../../../data/site';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return Object.keys(locales)
    .filter((locale) => locale !== 'en')
    .flatMap((locale) => languageSlugs.map((language) => ({ params: { locale, language } })));
}

const locale = Astro.params.locale as LocaleCode;
const language = Astro.params.language as LanguageSlug;
const copy = learnCopy(locale, language);
const ui = homeCopy[locale].ui;
const faq = learnFaq(locale, language);
const languageData = languages[language];
---
<BaseLayout title={copy.title} description={copy.description} locale={locale} path={`/learn/${language}`} faq={faq}>
  <Header locale={locale} />

  <main>
    <section class="section hero">
      <div class="container grid-2">
        <div>
          <p class="eyebrow">OpenWords</p>
          <h1>{copy.h1}</h1>
          <p class="lead">{copy.subtitle}</p>
          <div class="hero__actions">
            <StoreButtons locale={locale} />
          </div>
        </div>
        <img class="mascot" src="/svg_final_search_otter.dark.optimized.svg" alt={ui.searchMascotAlt} />
      </div>
    </section>

    <section class="section split-band">
      <div class="container">
        <h2>{copy.whoTitle}</h2>
        <p class="lead">{copy.who}</p>
      </div>
    </section>

    <section class="section">
      <div class="container grid-2">
        <div>
          <h2>{copy.previewTitle}</h2>
          <p class="lead">{copy.preview}</p>
        </div>
        {copy.previewSenses ? (
          <div class="dict-card">
            <div class="dict-card__header">
              <span class="dict-card__word">{copy.previewWord}</span>
              {copy.previewWordFamily && (
                <div class="dict-card__family">
                  {copy.previewWordFamily.join(' · ')}
                </div>
              )}
            </div>
            {copy.previewSenses.map((sense) => (
              <div class="dict-card__sense">
                <div class="dict-card__badges">
                  <span class="dict-card__level">{sense.level}</span>
                  <span class="dict-card__pos">{sense.pos}</span>
                </div>
                <p class="dict-card__def">{sense.definition}</p>
                <p class="dict-card__ex">"{sense.example}"</p>
              </div>
            ))}
          </div>
        ) : (
          <div class="word-preview">
            {languageData.examples.map((word, index) => (
              <article class="word-preview__item">
                <div class="word-preview__word">
                  <span>{word}</span>
                  <span class="word-preview__badge">{index === 0 ? 'A2' : index === 1 ? 'B1' : 'B2'}</span>
                </div>
                <p>{copy.wordPreviewItem}</p>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>

    <section class="section quiet-band">
      <div class="container">
        <h2>{copy.howTitle}</h2>
        <ol class="steps">
          {copy.how.map((step) => <li>{step}</li>)}
        </ol>
      </div>
    </section>

    <FAQ title={copy.faqTitle} items={faq} />

    <section class="section dark-band" id="download">
      <div class="container grid-2">
        <div>
          <h2>{copy.cta}</h2>
          <StoreButtons locale={locale} />
        </div>
        <img class="mascot" src="/svg_final_otter_favourites.dark.optimized.svg" alt={ui.savedCardsAlt} />
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</BaseLayout>

<style>
  .hero {
    padding-top: calc(80px + 5rem);
    background:
      radial-gradient(circle at 78% 32%, rgba(197, 163, 103, 0.14), transparent 24rem),
      linear-gradient(180deg, rgba(18, 20, 28, 0.2), rgba(13, 15, 22, 0.82));
  }

  .hero__actions {
    margin-top: 24px;
  }

  .dict-card {
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.04);
    overflow: hidden;
  }

  .dict-card__header {
    padding: 18px 20px 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .dict-card__word {
    display: block;
    color: var(--cream-100);
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 6px;
  }

  .dict-card__family {
    color: var(--night-500);
    font-size: 0.8rem;
    letter-spacing: 0.01em;
  }

  .dict-card__sense {
    padding: 14px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .dict-card__sense:last-child {
    border-bottom: none;
  }

  .dict-card__badges {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 6px;
  }

  .dict-card__level {
    padding: 2px 8px;
    border-radius: 999px;
    background: rgba(197, 163, 103, 0.15);
    color: var(--amber-400);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.06em;
  }

  .dict-card__pos {
    color: var(--night-500);
    font-size: 0.78rem;
    font-style: italic;
  }

  .dict-card__def {
    margin: 0 0 4px;
    color: var(--cream-200);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .dict-card__ex {
    margin: 0;
    color: var(--night-400);
    font-size: 0.82rem;
    font-style: italic;
    line-height: 1.5;
  }
</style>
